<vector xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:aapt="http://schemas.android.com/aapt"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <!-- Babybeam v3.1 (Extreme Ethereal Fidelity) -->

    <!-- Glossy Glass Container -->
    <path
        android:pathData="M20,20 h68 c6,0 10,4 10,10 v68 c0,6 -4,10 -10,10 h-68 c-6,0 -10,-4 -10,-10 v-68 c0,-6 4,-10 10,-10 z"
        android:strokeColor="#FFFFFF"
        android:strokeWidth="0.8"
        android:strokeAlpha="0.3">
        <aapt:attr name="android:fillColor">
            <gradient
                android:startX="20"
                android:startY="20"
                android:endX="88"
                android:endY="108"
                android:type="linear">
                <item android:color="#40FFFFFF" android:offset="0" />
                <item android:color="#00FFFFFF" android:offset="1" />
            </gradient>
        </aapt:attr>
    </path>

    <!-- Specular Highlight on Glass -->
    <path
        android:pathData="M25,25 c15,-5 35,-5 50,0"
        android:strokeColor="#FFFFFF"
        android:strokeWidth="3.5"
        android:strokeAlpha="0.6"
        android:strokeLineCap="round" />

    <!-- Concentric Glowing Rays (Outer) -->
    <path
        android:pathData="M54,12 C30,12 12,30 12,54"
        android:strokeWidth="4"
        android:strokeLineCap="round"
        android:strokeAlpha="0.4">
        <aapt:attr name="android:strokeColor">
            <gradient
                android:startX="12"
                android:startY="54"
                android:endX="54"
                android:endY="12"
                android:type="linear">
                <item android:color="#00E5FF" android:offset="0" />
                <item android:color="#E040FB" android:offset="1" />
            </gradient>
        </aapt:attr>
    </path>

    <!-- Concentric Glowing Rays (Inner) -->
    <path
        android:pathData="M65,22 C78,22 88,32 88,45"
        android:strokeWidth="5"
        android:strokeLineCap="round"
        android:strokeAlpha="0.2">
        <aapt:attr name="android:strokeColor">
            <gradient
                android:startX="65"
                android:startY="22"
                android:endX="88"
                android:endY="45"
                android:type="linear">
                <item android:color="#E040FB" android:offset="0" />
                <item android:color="#E1BEE7" android:offset="1" />
            </gradient>
        </aapt:attr>
    </path>

    <!-- WiFi/Beam Signal (Top Right) -->
    <path android:pathData="M78,35 c6,1 10,5 10,10 M78,42 c3,1 5,3 5,6"
        android:strokeColor="#00E5FF"
        android:strokeWidth="2.5"
        android:strokeLineCap="round"
        android:strokeAlpha="0.8" />

    <!-- Fluid Sleeping Baby Figure -->
    <group android:translateX="35" android:translateY="50">
        <!-- Head -->
        <path
            android:pathData="M8,8 a12,12 0 1 1 0,1"
            android:strokeColor="#FFFFFF"
            android:strokeWidth="2.8"
            android:strokeLineCap="round"
            android:fillColor="#00000000" />
        <!-- Closed Eyes -->
        <path
            android:pathData="M4,7 c1.5,1 3.5,1 5,0 M11,7 c1.5,1 3.5,1 5,0"
            android:strokeColor="#B2EBF2"
            android:strokeWidth="1"
            android:strokeLineCap="round" />
        <!-- Body / Swaddle -->
        <path
            android:pathData="M12,20 C25,45 60,35 55,20 C50,10 30,15 25,25"
            android:strokeColor="#FFFFFF"
            android:strokeWidth="3"
            android:strokeLineCap="round"
            android:fillColor="#00000000" />
        <!-- Soft Glow Overlay -->
        <path
            android:pathData="M8,8 a12,12 0 1 1 0,1 M12,20 C25,45 60,35 55,20 C50,10 30,15 25,25"
            android:strokeColor="#00E5FF"
            android:strokeWidth="6"
            android:strokeAlpha="0.15"
            android:strokeLineCap="round"
            android:fillColor="#00000000" />
    </group>

</vector>

