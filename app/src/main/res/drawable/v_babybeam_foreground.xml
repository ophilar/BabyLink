    <!-- Baby Profile (Glowing Highlight) -->
    <path
        android:pathData="M65,42C70,42 75,47 75,52C75,57 70,62 65,62C60,62 55,60 52,55C48,48 42,48 38,52C34,56 34,62 38,66C42,70 50,70 55,65"
